{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Preflight check results written by Claude in --ci mode",
  "type": "object",
  "required": ["verdict", "mode", "commit", "checks", "findings"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["READY", "READY_WITH_WARNINGS", "NOT_READY"]
    },
    "mode": {
      "type": "string",
      "enum": ["check-only", "managed"]
    },
    "commit": {
      "type": "string",
      "description": "Short SHA of the head commit"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "details"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "warning", "covered", "na"]
          },
          "details": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "nit"]
          },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "diff": {
            "type": "string",
            "description": "Proposed fix as a unified diff"
          }
        }
      }
    }
  }
}
